{
  "name": "tapdance-ai-director-workbench",
  "private": true,
  "version": "0.1.17",
  "description": "AI director workbench for planning storyboards, prompts, visual assets, and video generation tasks.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lazygunner/Tapdance.git"
  },
  "author": "lazygunner",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --port=3001 --host=0.0.0.0",
    "predev:bridge": "node scripts/ensure-node-native-modules.mjs",
    "dev:bridge": "node server/seedanceBridge.mjs",
    "predev:bridge:watch": "node scripts/ensure-node-native-modules.mjs",
    "dev:bridge:watch": "node --watch-path=server/seedanceBridge.mjs --watch-path=server/appStateStore.mjs --watch-path=server/betterSqlite3NativePaths.mjs --watch-preserve-output server/seedanceBridge.mjs",
    "dev:mock-api": "node server/mockApiServer.mjs",
    "predev:electron": "node scripts/ensure-electron-native-modules.mjs",
    "dev:electron": "electron-vite dev",
    "build": "vite build",
    "build:electron": "electron-vite build",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "pack:win": "electron-vite build && electron-builder --win",
    "pack:all": "electron-vite build && electron-builder --mac --win",
    "postinstall": "node scripts/postinstall.mjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview",
    "test": "node --experimental-transform-types --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "version:check-tag": "node scripts/check-version-tag.mjs",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@volcengine/tos-sdk": "^2.9.1",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.tapdance.ai-director",
    "productName": "Tapdance",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "out/**/*",
      "server/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "npmRebuild": true,
    "publish": [
      {
        "provider": "github",
        "owner": "lazygunner",
        "repo": "Tapdance"
      }
    ]
  }
}
